# ============================================================
# Clinic Booking System - Environment Configuration
# Copy this file to ".env" and adjust the values.
# ============================================================

# --- General ---
APP_NAME="Clinic Booking System"
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# --- Security ---
# Generate a strong secret with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# --- Database ---
# Default: local SQLite file (zero setup, great for development / small clinics)
DATABASE_URL=sqlite:///./clinic.db

# To scale up later, just point this to Postgres or MySQL and install the driver
# (see requirements.txt). No application code changes are required.
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/clinic_db
# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/clinic_db

# --- CORS (frontend origins allowed to call the API) ---
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# --- Default admin account (created automatically on first run via seed) ---
FIRST_ADMIN_EMAIL=admin@myclinic.com
FIRST_ADMIN_PASSWORD=Admin@12345
FIRST_ADMIN_NAME="Clinic Administrator"

# --- Verification codes (account verification / forgot password) ---
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# --- Email provider for OTP codes: "console" (default, just logs to the
# backend terminal - zero setup) or "smtp" (sends a real email) ---
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM_ADDRESS=no-reply@myclinic.com
EMAIL_FROM_NAME="Clinic Booking System"
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an "App Password"
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_USERNAME=apikey, SMTP_PASSWORD=<your SendGrid API key>

# --- SMS provider for OTP codes: "console" (default, just logs) or "twilio" ---
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# pip install twilio (see requirements.txt) before switching SMS_PROVIDER to "twilio"
