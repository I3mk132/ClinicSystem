# --- Clinic Bot service configuration ---

# Public API base of the clinic backend (no trailing slash).
CLINIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Gemini (Google AI Studio) API key + model.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Tenant registry: comma-separated tenant=apikey pairs.
# The apikey is the clinic's public X-API-Key (created in the admin panel).
# The tenant string is what the web widget sends in the X-Bot-Tenant header.
# Example: BOT_TENANTS=default=ck_live_abc123,acme=ck_live_def456
BOT_TENANTS=

# CORS: exact origins of the frontend(s) that embed the chat widget (comma-separated).
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Safety rails (optional overrides)
MAX_MESSAGE_CHARS=1000
RATE_LIMIT_PER_MINUTE=20
CONVERSATION_TTL_SECONDS=3600
